#!/bin/sh
# rustfmt --check on staged Rust files. Blocks the commit if any need
# formatting. Enable once per clone:
#
#     git config core.hooksPath .githooks
#
# CI runs the global `cargo fmt --all --check`; this is the fast local mirror.

files=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
[ -z "$files" ] && exit 0

if ! command -v rustfmt >/dev/null 2>&1; then
    echo "pre-commit: rustfmt not found (install via rustup) - skipping fmt check" >&2
    exit 0
fi

if ! echo "$files" | xargs rustfmt --edition 2024 --check >/dev/null 2>&1; then
    echo "pre-commit: staged Rust files are not formatted. Run:" >&2
    echo "    cargo fmt --all" >&2
    exit 1
fi
